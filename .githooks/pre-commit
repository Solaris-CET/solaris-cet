#!/usr/bin/env bash
set -euo pipefail

if ! command -v git >/dev/null 2>&1; then
  exit 0
fi

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  exit 0
fi

if ! git secrets --version >/dev/null 2>&1; then
  echo "git-secrets is required for this repo pre-commit hook."
  echo "Run: bash scripts/setup-git-secrets.sh"
  exit 1
fi

git secrets --scan

