#
# Copy this file to `.env` for local development.
# In Coolify, configure these keys in the environment variables UI.
#

# Public site origin for social share / clipboard (must include https; trailing slash optional)
# VITE_PUBLIC_SITE_URL=https://solaris-cet.com

# Optional: override build-time seal (Coolify/CI can set these so UI matches deployed commit)
# VITE_GIT_COMMIT_HASH=abc1234
# VITE_BUILD_TIMESTAMP=2026-03-31T12:00:00.000Z

# Optional: Google Search Console HTML tag token (injected into index.html at vite build; omit to ship without the meta)
# VITE_GOOGLE_SITE_VERIFICATION=abc123your_token_from_search_console

# Required for encrypted key resolution path
ENCRYPTION_SECRET=

# Grok provider (set encrypted or plaintext key)
GROK_API_KEY_ENC=
GROK_API_KEY=

# Gemini provider (set encrypted or plaintext key)
GEMINI_API_KEY_ENC=
GEMINI_API_KEY=

# Optional: secure auth token issued by /api/auth (HS256)
JWT_SECRET=

# Optional: Postgres for /api/auth, /api/audit (DB mode), /api/gdpr
DATABASE_URL=

# Newsletter (double opt-in) via Resend
# RESEND_API_KEY=re_...
# NEWSLETTER_FROM="Solaris CET <newsletter@solaris-cet.com>"

# Optional: TON Center RPC for /api/wallet/balance
# TONCENTER_RPC_URL=https://toncenter.com/api/v2/jsonRPC
TONCENTER_RPC_URL=
TONCENTER_API_KEY=

# Required for /r2a (task submission). Address of the deployed R2ATaskBoard contract.
VITE_R2A_TASK_CONTRACT_ADDRESS=

# Optional: Upstash Redis REST (rate limit /api/chat, cache /api/cache)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: UX analytics script (loaded only after cookie consent: analytics=true)
VITE_UX_TEST_SRC=

# Optional: Google Analytics 4 (gtag.js) + Google Tag Manager
# Note: both are loaded only after cookie consent (analytics=true) AND first user interaction.
VITE_GA4_MEASUREMENT_ID=
VITE_GTM_CONTAINER_ID=
# Optional: set to 1 to enable extra debug flags for local validation
VITE_ANALYTICS_DEBUG=0

# Optional: Sentry (frontend)
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0

# Optional: Sentry (backend / Node server)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0

# Optional: Sentry sourcemaps upload (build-time)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_URL=

# Optional: Prometheus metrics protection token
METRICS_TOKEN=

# Optional: Uptime heartbeat outgoing pings (cron)
UPTIME_HEARTBEAT_URL=
