{
  "name": "solaris-cet",
  "description": "Solaris CET — Real-World Asset Token landing page on TON Blockchain. Powered by the RAV Protocol with dual-AI: Grok × Gemini.",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "Solaris CET Team",
    "url": "https://github.com/Solaris-CET"
  },
  "homepage": "https://solaris-cet.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Solaris-CET/solaris-cet.git"
  },
  "keywords": [
    "solaris",
    "cet",
    "ton",
    "blockchain",
    "rwa",
    "real-world-asset",
    "defi",
    "token",
    "dedust",
    "rav-protocol",
    "react",
    "typescript",
    "vite"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "predev": "node ../scripts/sync-sovereign-to-public.mjs && node ../scripts/sync-apocalypse-to-public.mjs && node ../scripts/sync-onnxruntime-assets.mjs && node ../scripts/inject-sovereign-build-seal.mjs && node ../scripts/generate-release-notes.mjs && node scripts/generate-seo-files.mjs && node scripts/generate-legal-digests.mjs",
    "dev": "../node_modules/.bin/vite",
    "prebuild": "node ../scripts/write-build-info.mjs && node ../scripts/fix-phosphor-webcomponents.mjs && node ../scripts/sync-sovereign-to-public.mjs && node ../scripts/sync-apocalypse-to-public.mjs && node ../scripts/sync-onnxruntime-assets.mjs && node ../scripts/inject-sovereign-build-seal.mjs && node ../scripts/generate-release-notes.mjs && node scripts/generate-seo-files.mjs && node scripts/generate-legal-digests.mjs",
    "build": "../node_modules/.bin/tsc -b && ../node_modules/.bin/vite build",
    "build:ci": "node scripts/generate-legal-digests.mjs && tsc -b --pretty false && vite build --logLevel warn",
    "start": "../node_modules/.bin/vite preview --host 0.0.0.0 --port ${PORT:-4173}",
    "api:build": "../node_modules/.bin/tsc -p tsconfig.api.json",
    "start:node": "node server/index.cjs",
    "start:full": "npm run build && npm run api:build && npm run start:node",
    "typecheck": "../node_modules/.bin/tsc --noEmit -p tsconfig.app.json && ../node_modules/.bin/tsc --noEmit -p tsconfig.test.json && ../node_modules/.bin/tsc --noEmit -p tsconfig.node.json && ../node_modules/.bin/tsc --noEmit -p tsconfig.e2e.json",
    "lint": "../node_modules/.bin/eslint . --quiet",
    "audit:swarm": "node ../scripts/swarm-audit/audit-processor.mjs",
    "preview": "../node_modules/.bin/vite preview",
    "preview:e2e": "NODE_OPTIONS=--max-old-space-size=8192 ../node_modules/.bin/vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "test": "../node_modules/.bin/vitest run",
    "test:watch": "../node_modules/.bin/vitest",
    "test:coverage": "../node_modules/.bin/vitest run --coverage",
    "test:contract": "../node_modules/.bin/vitest run src/contract-tests",
    "pretest:e2e": "node ../scripts/check-dist-for-e2e.mjs && npm run api:build",
    "test:e2e": "node scripts/run-e2e-batched.mjs",
    "test:e2e:raw": "../node_modules/.bin/playwright test",
    "test:e2e:stable": "PW_WORKERS=1 npm run test:e2e",
    "test:e2e:fresh": "npm run build && npm run test:e2e:stable",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "verify:all": "npm run verify && npm run test:e2e:stable",
    "verify:full": "npm run verify:all",
    "continue": "bash ../scripts/continue-from-here.sh",
    "db:generate": "../node_modules/.bin/drizzle-kit generate",
    "db:push": "../node_modules/.bin/drizzle-kit push",
    "db:studio": "../node_modules/.bin/drizzle-kit studio",
    "storybook": "../node_modules/.bin/storybook dev -p 6006",
    "storybook:build": "../node_modules/.bin/storybook build"
  },
